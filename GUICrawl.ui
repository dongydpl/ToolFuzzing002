  <property name="styleSheet">
   <string notr="true">/* ===================================================
   1. NỀN CHUNG VÀ CÁC Ô NHẬP LIỆU / HIỂN THỊ
   =================================================== */
QWidget#centralwidget {
    background-color: #f4f6f9;
}

QTextEdit, QTextBrowser {
    background-color: #ffffff;
    border: 1px solid #ced4da;
    border-radius: 8px;
    padding: 6px;
    font-size: 13px;
}

/* ===================================================
   2. BẢNG KẾT QUẢ (TABLE WIDGET) VÀ TAB WIDGET
   =================================================== */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #ced4da;
    border-radius: 8px;
    gridline-color: #e9ecef;
    font-size: 13px;
}

QHeaderView::section {
    background-color: #343a40;
    color: #ffffff;
    font-weight: bold;
    padding: 5px;
    border: none;
    border-right: 1px solid #495057;
}

QTabWidget::pane {
    border: 1px solid #ced4da;
    border-radius: 6px;
    background: #ffffff;
}

QTabBar::tab {
    background: #e9ecef;
    border: 1px solid #ced4da;
    padding: 6px 16px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #ffffff;
    border-bottom-color: #ffffff;
    font-weight: bold;
    color: #0d6efd;
}

/* ===================================================
   3. NÚT BẤM (BO TRÒN, ĐỔ MÀU THEO CHỨC NĂNG)
   =================================================== */
QPushButton {
    color: #ffffff;
    font-weight: bold;
    font-size: 13px;
    border-radius: 12px; /* Bo tròn mềm mại ở đây */
    padding: 6px 12px;
    border: none;
}

/* Trạng thái nút bị khóa (khi chưa có link) */
QPushButton:disabled {
    background-color: #ced4da;
    color: #6c757d;
}

/* ---&gt; Nút Quét (jBntScan) - Màu Xanh Dương &lt;--- */
QPushButton#jBntScan {
    background-color: #0d6efd; 
}
QPushButton#jBntScan:hover {
    background-color: #0b5ed7; 
}

/* ---&gt; Nút Path Traversal (pushButton) - Màu Cam &lt;--- */
QPushButton#pushButton {
    background-color: #fd7e14;
}
QPushButton#pushButton:hover {
    background-color: #e85e0c;
}

/* ---&gt; Nút SQLi (btnSQLi) - Màu Đỏ &lt;--- */
QPushButton#btnSQLi {
    background-color: #dc3545;
}
QPushButton#btnSQLi:hover {
    background-color: #c82333;
}

/* ---&gt; Nút XSS (btnXSS) - Màu Xanh Lá &lt;--- */
QPushButton#btnXSS {
    background-color: #198754;
}
QPushButton#btnXSS:hover {
    background-color: #157347;
}</string>
