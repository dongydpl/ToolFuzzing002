  <property name="styleSheet">
   <string notr="true">/* ===================================================
   1. NỀN CHUNG VÀ CÁC CHỮ (TEXT/LABEL)
   =================================================== */
QWidget#centralwidget {
    background-color: #f8f9fa; /* Màu nền xám trắng hiện đại */
}

/* SỬA LỖI TÀNG HÌNH TIÊU ĐỀ CHÍNH */
QLabel#label {
    color: #2c3e50; /* Màu xám đen đậm cho chữ Tool Fuzzing */
    font-weight: bold;
}

/* Chữ &quot;Nhập URL&quot; */
QLabel#label_2 {
    color: #34495e; 
    font-weight: bold;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, Roboto, Arial, sans-serif;
}

/* ===================================================
   2. CÁC Ô NHẬP LIỆU VÀ HIỂN THỊ LOG (TEXT AREA)
   =================================================== */
QTextEdit, QTextBrowser {
    background-color: #ffffff;
    border: 2px solid #ced4da;
    border-radius: 8px;
    padding: 8px;
    font-size: 14px;
    color: #212529;
}

/* Hiệu ứng khi bấm chuột vào ô nhập URL */
QTextEdit:focus {
    border: 2px solid #86b7fe; 
}

/* ===================================================
   3. BẢNG KẾT QUẢ VÀ CÁC TAB (TAB WIDGET)
   =================================================== */
QTabWidget::pane {
    border: 1px solid #ced4da;
    border-radius: 8px;
    background: #ffffff;
    top: -1px;
}

QTabBar::tab {
    background: #e9ecef;
    border: 1px solid #ced4da;
    padding: 8px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
    color: #495057;
    font-weight: bold;
}

QTabBar::tab:selected {
    background: #ffffff;
    border-bottom-color: #ffffff;
    color: #0d6efd; /* Chữ màu xanh khi chọn tab */
}

QTableWidget {
    background-color: #ffffff;
    border: none;
    gridline-color: #e9ecef;
    font-size: 13px;
    color: #212529;
}

QHeaderView::section {
    background-color: #343a40; /* Nền đen nhạt cho tiêu đề bảng */
    color: #ffffff;
    font-weight: bold;
    padding: 8px;
    border: none;
    border-right: 1px solid #495057;
}

/* ===================================================
   4. NÚT BẤM (BUTTON) - PHONG CÁCH PASTEL BO TRÒN
   =================================================== */
QPushButton {
    border-radius: 15px; /* Bo góc viên thuốc */
    font-family: &quot;Segoe UI&quot;, Roboto, Arial, sans-serif;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 16px;
    border: 2px solid transparent;
}

QPushButton:disabled {
    background-color: #e9ecef;
    color: #adb5bd;
}

/* ---&gt; Nút Quét (Màu Xanh lam Pastel) &lt;--- */
QPushButton#jBntScan { background-color: #cce5ff; color: #004085; }
QPushButton#jBntScan:hover { background-color: #b8daff; border: 2px solid #004085; }

/* ---&gt; Nút Path Traversal (Màu Cam Pastel) &lt;--- */
QPushButton#pushButton { background-color: #fff3cd; color: #856404; }
QPushButton#pushButton:hover { background-color: #ffe8a1; border: 2px solid #856404; }

/* ---&gt; Nút SQLi (Màu Đỏ Pastel) &lt;--- */
QPushButton#btnSQLi { background-color: #f8d7da; color: #721c24; }
QPushButton#btnSQLi:hover { background-color: #f5c6cb; border: 2px solid #721c24; }

/* ---&gt; Nút XSS (Màu Xanh lá Pastel) &lt;--- */
QPushButton#btnXSS { background-color: #d4edda; color: #155724; }
QPushButton#btnXSS:hover { background-color: #c3e6cb; border: 2px solid #155724; }</string>
